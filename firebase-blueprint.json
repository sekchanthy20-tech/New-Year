{
  "entities": {
    "AllowedUser": {
      "title": "Allowed User",
      "description": "A user who is allowed to access the system.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "registeredAt": { "type": "number" },
        "lastLogin": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "accessCodeUsed": { "type": "string" }
      },
      "required": ["email", "name", "registeredAt", "lastLogin", "status", "accessCodeUsed"]
    },
    "UserSettings": {
      "title": "User Settings",
      "description": "Branding and other settings for a specific user.",
      "type": "object",
      "properties": {
        "brandSettings": {
          "type": "object",
          "properties": {
            "fontSize": { "type": "number" },
            "fontWeight": { "type": "string" },
            "letterSpacing": { "type": "number" },
            "textTransform": { "type": "string", "enum": ["uppercase", "none", "capitalize"] },
            "schoolName": { "type": "string" },
            "schoolAddress": { "type": "string" },
            "logos": { "type": "array", "items": { "type": "string" } },
            "logoWidth": { "type": "number" },
            "logoData": { "type": "string" }
          }
        }
      }
    },
    "UserHistory": {
      "title": "User History",
      "description": "History of generated tests for a specific user.",
      "type": "object",
      "properties": {
        "history": {
          "type": "array",
          "items": { "$ref": "GeneratedTest" }
        }
      }
    },
    "GeneratedTest": {
      "title": "Generated Test",
      "description": "A test generated by the neural engine.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "number" },
        "promptId": { "type": "string" },
        "logicSnapshot": { "type": "string" },
        "module": { "type": "string" },
        "level": { "type": "string" },
        "topic": { "type": "string" },
        "authorName": { "type": "string" },
        "authorCode": { "type": "string" },
        "authorEmail": { "type": "string" }
      },
      "required": ["id", "title", "content", "timestamp", "authorEmail"]
    },
    "User": {
      "title": "User",
      "description": "User profile with roles.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["admin", "user"] }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles for role management."
    },
    "/user_settings/{email}": {
      "schema": "UserSettings",
      "description": "User-specific branding settings."
    },
    "/user_history/{email}": {
      "schema": "UserHistory",
      "description": "User-specific test history."
    },
    "/generatedTests/{testId}": {
      "schema": "GeneratedTest",
      "description": "Individual generated tests."
    },
    "/test/connection": {
      "schema": "object",
      "description": "Connection test document."
    }
  }
}
